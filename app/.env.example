# Toggle the in-memory mock data source vs a real HTTP backend.
VITE_USE_MOCK=true
# Base URL for the real logistics API (used when VITE_USE_MOCK=false).
VITE_API_BASE_URL=https://api.example.com
# Realtime telemetry WebSocket endpoint (used when VITE_USE_MOCK=false).
VITE_WS_URL=wss://api.example.com/realtime
# Attach AI triage suggestions to tasks (set to "false" to disable).
VITE_AI_TRIAGE=true
# Optional: base URL of the triage inference service (the client POSTs to
# `${VITE_TRIAGE_URL}/triage`). When unset, the local heuristic model is used.
VITE_TRIAGE_URL=
# Optional: generate N synthetic tasks to exercise lane virtualization at scale.
VITE_SEED_COUNT=
# Bearer token sent to the API/WebSocket (must match the server's API_TOKEN).
VITE_DEV_TOKEN=dev-token
# Refresh token for the 401 auto-refresh flow (must match the server's REFRESH_TOKEN).
VITE_DEV_REFRESH_TOKEN=dev-refresh
# OTLP/HTTP traces collector endpoint (set to export client spans).
VITE_OTLP_URL=
# OTLP resource attributes (per deployment).
VITE_SERVICE_NAME=shiptivitas-app
VITE_SERVICE_VERSION=0.1.0
VITE_DEPLOY_ENV=development
# Head-based trace sample rate 0..1 (1 = export every trace).
VITE_OTLP_SAMPLE_RATE=1
# Extra OTLP headers for hosted vendors, e.g. x-honeycomb-team=KEY
VITE_OTLP_HEADERS=
