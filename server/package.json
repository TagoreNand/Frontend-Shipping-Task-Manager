{
  "name": "shiptivitas-server",
  "version": "0.1.0",
  "private": true,
  "description": "Persistence + realtime backend for the Shiptivitas logistics board.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.22.2",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "ioredis-mock": "^8.13.1",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
